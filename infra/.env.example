# Sharpside 开发环境配置示例
# 复制为 .env 并按需修改

# 构建期代理（docker build 拉 crates.io / rustup 用）。
# 留空=直连；受限网络设为宿主代理：BUILD_HTTP_PROXY=http://host.docker.internal:7890
# （compose build.extra_hosts 已加 host-gateway 映射，容器内可解析 host.docker.internal）。
# BUILD_HTTP_PROXY=http://host.docker.internal:7890
# BUILD_HTTPS_PROXY=http://host.docker.internal:7890
# BUILD_NO_PROXY=localhost,127.0.0.1

# 运行环境标识。生产部署必须设为 production：
#   - 启用密钥强校验（JWT_SECRET / TG_BOT_SECRET / ADMIN_TOKEN / VENUE_HUB_ADMIN_TOKEN
#     / DAEMON_API_KEY / INTERNAL_SIGNAL_SECRET / FOLLOW_SIGNAL_SECRET / ADMIN_SESSION_SECRET
#     空值、已知默认值或长度 <32 则启动 panic）
#   - 强制关闭网关开发端点 /dev/token（忽略 DEV_ENDPOINTS_ENABLED）
#   - 禁止 DevKms（SHARPSIDE_KMS_DEV_PLAINTEXT）：库内密钥可逆，须设 SHARPSIDE_KMS_MASTER_KEY_PATH
#     （LocalKms 站内签为生产默认；不接亚马逊等云 KMS）
#   - admin 强制 OIDC（见下方 OIDC_*）
# 开发留空即可。
# APP_ENV=production
#   注：web 服务据此（/config.js 注入 window.__SHARPSIDE__.production）隐藏前端测试开通入口
#   （订阅页「直接开通（测试）」与 $X/mo 占位），生产构建无白嫖 Pro+ 路径。
# 生产编排：docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file ../.env up -d
# 清单：docs/DEPLOY_CHECKLIST.md

# 生产 KMS（LocalKms）：32 字节 master key 文件路径；account 与 copier 必须同路径/同内容。
# 首次启动若不存在会自动生成（0600）。务必备份该文件。
# SHARPSIDE_KMS_MASTER_KEY_PATH=/var/lib/sharpside/kms-master.key
# 仅本地开发可用（生产禁止）：
# SHARPSIDE_KMS_DEV_PLAINTEXT=1

DATABASE_URL=postgres://sharpside:sharpside_dev@localhost:5432/sharpside
REDIS_URL=redis://localhost:6379/
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=sharpside
S3_SECRET_KEY=sharpside_dev
S3_BUCKET=sharpside

RUST_LOG=info,sharpside=debug
# 安全修复 4.2：日志格式。production 默认 JSON；开发可设 LOG_FORMAT=json 强制 JSON。
# LOG_FORMAT=json
# deadletter 告警 webhook（venue-hub signal_replay 入死信时 POST JSON；留空则仅日志+metrics）
# ALERT_WEBHOOK_URL=https://hooks.example.com/sharpside

# JWT 签名密钥（生产用 KMS / SOPS 注入，开发用本地随机）
JWT_SECRET=dev_only_do_not_use_in_production

# gateway（BFF + 鉴权 + 限流）—— 与 web 8080 错开
GATEWAY_LISTEN_ADDR=0.0.0.0:8085

# Venue 开关（venue-hub 按 VENUE_<NAME>__ENABLED 注册 adapter）
VENUE_POLYMARKET_ENABLED=true
VENUE_KALSHI_ENABLED=false
VENUE_MANIFOLD_ENABLED=false
VENUE_ZEITGEIST_ENABLED=false
VENUE_AZURO_ENABLED=false

# Polymarket API base 覆盖（留空用默认线上地址）。
# 生产可用于自托管代理/镜像；离线联调指向本地 mock：
#   python3 infra/mock/polymarket_mock.py 9200
#   POLYMARKET_DATA_API_URL=http://127.0.0.1:9200 （gamma/clob 同）
POLYMARKET_DATA_API_URL=
POLYMARKET_GAMMA_API_URL=
POLYMARKET_CLOB_API_URL=

# Polygon JSON-RPC endpoint（链上余额兜底用）。
# 离线预配（POLYMARKET_PROVISION_LIVE=0）时 CLOB /balance-allowance 不可用，
# copier /me/wallet、/me/portfolio 走 RPC eth_call 读 Deposit Wallet 的 pUSD balanceOf。
# 留空用默认 https://polygon-bor.publicnode.com（多数地区可直连，不依赖 Clash）。
# 若公共 RPC 也被墙，设 POLYGON_RPC_URL=自建节点，或 POLYGON_RPC_PROXY=http://host.docker.internal:7890。
POLYGON_RPC_URL=
POLYGON_RPC_PROXY=

# venue-hub 监听与 worker 间隔（秒）
VENUE_HUB_LISTEN_ADDR=0.0.0.0:8081
# venue-hub 写端点（/traders/import*）admin 鉴权令牌：请求须带 Authorization: Bearer <token>。
# 生产必须设独立强 token（infra/import_addresses.sh 读 VENUE_HUB_ADMIN_TOKEN）。
VENUE_HUB_ADMIN_TOKEN=dev-admin-token
# venue-hub 调 follow /internal/signals 携带的 X-Internal-Secret，须与 follow 的 INTERNAL_SIGNAL_SECRET 一致。
FOLLOW_SIGNAL_SECRET=
DB_MAX_CONNECTIONS=10
WORKER_INGEST_SECS=300
WORKER_MAPPING_SECS=600
WORKER_IDENTITY_SECS=600
WORKER_PERF_SECS=900
WORKER_HOT_SECS=5
# 自适应扫描（Phase B）：hot_secs 现为调度节拍（多久检查一次"谁到期"），非扫描间隔。
# 真实扫描周期 = 热钥 per-row scan_interval_secs（admin 可配 10–60s）/ 跟随类 follow_scan_secs。
# 到期目标的拉取由 PolymarketClient governor 令牌桶节流（Phase A），故可激进调小 hot_secs 而不打爆 Polymarket。
WORKER_FOLLOW_SCAN_SECS=10
WORKER_HOT_DUE_CAP=50
# 第 3 层：trade_watch 逐笔成交信号主源（每 tick 全量轮询被跟随/热钥地址 /trades，governor 限流）。
# 默认 3s；Data API 成交可见延迟是物理下限，下调无益。hot（positions diff）降级为对账补漏，落后一轮闭合窗口。
WORKER_TRADE_WATCH_SECS=3
# official_pnl worker：排行榜官方盈亏 + `/value` 快照 delta 兜底（非榜地址）。
# 间隔越短 / batch 越大，非榜地址 official_pnl 成熟越快，但会吃 Data API `/value` 配额（~8 rps）。
# 小池（<500 可见地址）可调到 300s / 200；大池保持默认以免饿死 hot/positions。
WORKER_OFFICIAL_PNL_SECS=600
WORKER_OFFICIAL_VALUE_BATCH=100
# 安全修复 4.3：readyz 停滞阈值（秒）。0 = 跳过该项检查。
# WORKER_STALE_SECS=600
# INGEST_STALE_SECS=1800

# backfill worker：异步回填 raw_trades（ingest 只存身份，此处拉成交写 raw_trades）
WORKER_BACKFILL_SECS=120
WORKER_BACKFILL_BATCH=25
WORKER_BACKFILL_REFRESH_DAYS=7

# 启发式阈值（0–1）
AUTO_MATCH_THRESHOLD=0.7
IDENTITY_THRESHOLD=0.6

# account 服务（用户/订阅/凭证/daemon_api_key）
ACCOUNT_LISTEN_ADDR=0.0.0.0:8084
JWT_TTL_SECONDS=1800
# 安全修复 3.1：会话 cookie 的 Secure 属性。生产（HTTPS）须为 1；本地 HTTP 开发设 0（否则浏览器拒收 cookie）。
# 缺省按 APP_ENV=production 推断（生产 true / 开发 false）。
# COOKIE_SECURE=1
PBKDF2_ITERATIONS=100000
# /auth/* 限流：每分钟每 IP 最大请求数（防暴力撞库 / 注册刷量，默认 10）
AUTH_RATE_LIMIT_PER_MIN=10
# 钱包登录（SIWE / EIP-4361，模型 A · 身份钱包）
# 前端 SIWE 消息的 domain 字段须等于此值（防钓鱼）；默认 localhost
PUBLIC_DOMAIN=localhost
# SIWE 消息 issued_at 距今的最大秒数（防陈旧重放，默认 300）；同时作 auth_nonces TTL
SIWE_MAX_AGE_SECS=300
# 允许的 chainId 白名单，逗号分隔（Polymarket=137，主网=1）
SIWE_ALLOWED_CHAIN_IDS=137,1
# SIWE URI：推荐 origin（nonce 响应返回给前端）。默认按 PUBLIC_DOMAIN 推导。
# PUBLIC_URI=https://app.example.com
# 额外允许的 URI（逗号分隔）；localhost 默认已含常见本地端口
# SIWE_ALLOWED_URIS=https://app.example.com,https://www.example.com
# TG bot 代用户换 JWT 的共享密钥（tg-bot 与 account 须一致）
TG_BOT_SECRET=dev-tg-bot-secret
# 内部管理端点（POST /internal/venue-credentials/...、POST /internal/billing/confirm）共享密钥。
# gateway 对 /api/account/internal/* 返回 404；仅私网调用。生产须 ≥32 且非默认。
ACCOUNT_INTERNAL_SECRET=e2e-account-internal-secret

# —— Pro+ USDC 计费（Polygon，account 服务）——
# 平台收款地址（小写 0x）。未设置则 POST /me/billing/invoices 返回「计费未配置」。
# BILLING_TREASURY_ADDRESS=0x...
# Polygon native USDC（默认如下；勿与 Polymarket pUSD collateral 混淆）
# BILLING_USDC_ADDRESS=0x3c499c542cef5e3811e1192ce70d8cc03d5c3359
# BILLING_CHAIN_ID=137
# BILLING_PRICE_30D_USDC=30
# BILLING_PRICE_90D_USDC=72
# BILLING_INVOICE_TTL_SECS=1800
# BILLING_GRACE_SECS=86400
# BILLING_CONFIRMATIONS=30
# 用户粘贴 tx 后，account worker 用 POLYGON_RPC_URL 拉 receipt；也可不粘贴，靠 eth_getLogs 按金额认领。
# BILLING_LOGS_LOOKBACK_BLOCKS=5000
# BILLING_LOGS_CHUNK_BLOCKS=1000
# BILLING_REQUIRE_LINKED_WALLET=false
# BILLING_WORKER_ENABLED=true
# WORKER_BILLING_SECS=15
# WORKER_BILLING_EXPIRY_SECS=300

# follow 服务（跟随关系 CRUD + 信号派生）
FOLLOW_LISTEN_ADDR=0.0.0.0:8082
VENUE_HUB_URL=http://127.0.0.1:8081
# 内部信号鉴权：venue-hub 检出仓位变化后 POST /internal/signals，须带 X-Internal-Secret
# 匹配此值。follow 侧强制非空（空串即拒收信号）。须与 venue-hub 的 FOLLOW_SIGNAL_SECRET 一致。
INTERNAL_SIGNAL_SECRET=

# copier 服务（通道×Venue 执行 + 风控）
COPIER_LISTEN_ADDR=0.0.0.0:8083
WORKER_EXEC_SECS=5
# 干跑：不调 Venue::place_order，合成成交。离线/无凭证用 true。
COPIER_DRY_RUN=true
# 第 2 层：跟单下单类型。FAK（默认）= 立即成交能成交的部分，剩余取消，跟单更易"跟上"；
# GTC = 挂单等成交（易因行情已走而 120s 超时撤单）；FOK = 整单立即成交否则整单取消。
COPIER_ORDER_TYPE=FAK
# 激进定价：买取 best_ask、卖取 best_bid（吃对手盘立即成交），并以信号价 ± max_slippage 钳制。
# 关闭则按信号价下单（FAK 仍 IOC 但不主动跨越盘口，成交率低）。生产跟单建议 true。
COPIER_AGGRESSIVE_PRICING=true
RISK_DAILY_MAX_NOTIONAL=5000
RISK_MAX_OPEN_POSITIONS=20
RISK_RAPID_FLIP_WINDOW_SECS=60
RISK_RAPID_FLIP_MAX_COUNT=5
RISK_CONSECUTIVE_LOSS_LIMIT=3
# 成交对账 worker：扫 submitted 指令查 Venue 真实成交回写（替代"提交即记全成"）。
# Channel A 真钱路径必需；dry_run 路径不进 submitted，不受影响。
WORKER_RECONCILE_SECS=15
# submitted 超时阈值：限价单挂单超过此秒数仍 LIVE 则撤单置 cancelled（避免长期占用资金）。
# FAK/FOK 为 IOC，下单即终态（成交或剩余取消），通常不进此超时；GTC 挂单场景才依赖此值。
RECONCILE_TIMEOUT_SECS=120
RECONCILE_WORKER_ENABLED=true
# dispatched 超时回收 worker（copier 崩溃后卡死 dispatched 单兜底，仅置 failed 不重下）。
WORKER_RECLAIM_SECS=60
DISPATCHED_TIMEOUT_SECS=600
RECLAIM_WORKER_ENABLED=true

# daemon（通道 B，自托管）
COPIER_URL=http://127.0.0.1:8083
DAEMON_USER_ID=
DAEMON_API_KEY=
DAEMON_POLL_SECS=10
DAEMON_DRY_RUN=true
DAEMON_LOCAL_MAX_NOTIONAL=1000
# headless：非 TTY 自动启用（e2e/systemd/CI）；显式置 1 强制不进 ratatui TUI，日志走 tracing。
DAEMON_HEADLESS=0
# 通道 B 本地签名（alloy EIP-712）。dry_run=false 时必填私钥；默认 dry-sign 不提交 CLOB。
# POLYMARKET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# POLYMARKET_CLOB_POST=0
# 通道 A（copier）dev 路径同：POLYMARKET_DEV_PRIVATE_KEY 或 POLYMARKET_DEV_PLAINTEXT_HANDLE=1

# web（最小前端）
WEB_LISTEN_ADDR=0.0.0.0:8080
GATEWAY_URL=http://127.0.0.1:8085

# admin（运营后台 API）
ADMIN_LISTEN_ADDR=0.0.0.0:8086
ADMIN_TOKEN=dev-admin-token

# ── Admin OIDC（安全修复 3.3；生产强制，缺一则 admin 拒启）──
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://admin.example.com/api/auth/oidc/callback
# OIDC_ALLOWED_EMAILS=ops@example.com,admin@example.com
# ADMIN_SESSION_SECRET=replace-with-32plus-char-random-secret
# ADMIN_SESSION_TTL_SECONDS=3600
# COOKIE_SECURE=1

# ── 生产 compose 口令（docker-compose.prod.yml 必填）──
# POSTGRES_USER=sharpside
# POSTGRES_PASSWORD=replace-with-strong-password
# POSTGRES_DB=sharpside
# MINIO_ROOT_USER=sharpside
# MINIO_ROOT_PASSWORD=replace-with-strong-password

# tg-bot · 通道 A（teloxide 长轮询，平台代签 session wallet）
# TG_BOT_TOKEN 留空则 bot 启动时优雅退出；须与 account 的 TG_BOT_SECRET 一致
# 生产：TG_BOT_SECRET 须 ≥32 字符且非默认（assert_secret）
TG_BOT_TOKEN=
TG_BOT_SECRET=dev-tg-bot-secret
TG_DEFAULT_AMOUNT=50
ACCOUNT_URL=http://127.0.0.1:8084
FOLLOW_URL=http://127.0.0.1:8082
VENUE_HUB_URL=http://127.0.0.1:8081

# 影子模式（venue-hub shadow worker）
WORKER_SHADOW_SECS=1800
SHADOW_DRY_RUN=true
SHADOW_THIRD_PARTY_URL=http://127.0.0.1:9100

# ── 通道 A · Polymarket Builder / Relayer 凭证 ──
# 对应 docs/CHANNEL_A_SIGNING.md §3 / §7。真实值见 .env（gitignored）。
# 申请：polymarket.com/settings?tab=builder → 建档 → 复制 Builder Code → 「+ Create New」生成 API key/secret/passphrase
# Builder 凭证（CLOB L2 HMAC 鉴权）
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=
# Builder 归因 code（bytes32，公开；订单 builderCode 字段 + X-Builder-Code header）
POLYMARKET_BUILDER_CODE=
POLYMARKET_BUILDER_ADDRESS=
# Relayer 凭证（gasless 部署 deposit wallet；Settings > API Keys，独立于 Builder 凭证）
POLYMARKET_RELAYER_API_KEY=
POLYMARKET_RELAYER_API_KEY_ADDRESS=
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com
POLYMARKET_RELAYER_PROXY=
# Deposit Wallet 预配开关
POLYMARKET_PROVISION_LIVE=0

